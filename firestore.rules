rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDeviceOwner(deviceId) {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/devices/$(deviceId))
             && get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerUid == request.auth.uid;
    }

    function requesterQrId() {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.qrId
             : null;
    }

    function isLinkedFamilyMember(deviceId) {
      let qrId = requesterQrId();
      return isAuthenticated()
             && (
               exists(/databases/$(database)/documents/devices/$(deviceId)/familyMembers/$(request.auth.uid))
               || (
                 qrId is string
                 && exists(/databases/$(database)/documents/devices/$(deviceId)/familyMembers/$(qrId))
               )
             );
    }

    function isDeviceReadable(deviceId) {
      return isDeviceOwner(deviceId) || isLinkedFamilyMember(deviceId);
    }

    // V3: Check if two users have a mutual, explicitly accepted family link.
    // Pending invitation documents must never unlock live location, SOS, or status reads.
    function hasMutualFamilyLink(ownerUid, otherUid) {
      return ownerUid is string
             && otherUid is string
             && ownerUid != otherUid
             && exists(/databases/$(database)/documents/users/$(ownerUid)/familyMembers/$(otherUid))
             && get(/databases/$(database)/documents/users/$(ownerUid)/familyMembers/$(otherUid)).data.approvalState == 'mutual'
             && exists(/databases/$(database)/documents/users/$(otherUid)/familyMembers/$(ownerUid))
             && get(/databases/$(database)/documents/users/$(otherUid)/familyMembers/$(ownerUid)).data.approvalState == 'mutual';
    }

    function sharesFamilyWith(targetUid) {
      return isAuthenticated()
             && hasMutualFamilyLink(request.auth.uid, targetUid);
    }

    // One accepted invitation direction is the consent proof. The accepted status
    // can only be written by the recipient of an existing pending request, so a
    // second reverse request is not required to unlock the mutual family finalizer.
    function hasAcceptedContactRequest(userA, userB) {
      return userA is string
             && userB is string
             && userA != userB
             && (
               (
                 exists(/databases/$(database)/documents/users/$(userA)/contactRequests/$(userB))
                 && get(/databases/$(database)/documents/users/$(userA)/contactRequests/$(userB)).data.status == 'accepted'
               )
               || (
                 exists(/databases/$(database)/documents/users/$(userB)/contactRequests/$(userA))
                 && get(/databases/$(database)/documents/users/$(userB)/contactRequests/$(userA)).data.status == 'accepted'
               )
             );
    }

    function isPendingFamilyLinkWrite(userId, otherUid) {
      return request.resource.data.familyId is string
             && request.resource.data.approvalState == 'pending'
             && request.resource.data.requestedBy is string
             && request.resource.data.requestedBy == request.auth.uid
             && (
               request.auth.uid == userId
               || (
                 request.auth.uid == otherUid
                 && exists(/databases/$(database)/documents/users/$(request.auth.uid)/familyMembers/$(userId))
               )
             );
    }

    function isAcceptedFamilyLinkWrite(userId, otherUid) {
      return request.resource.data.familyId is string
             && request.resource.data.approvalState == 'mutual'
             && hasAcceptedContactRequest(userId, otherUid)
             && (request.auth.uid == userId || request.auth.uid == otherUid);
    }

    function isSenderOwned(senderDeviceId) {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/devices/$(senderDeviceId))
             && get(/databases/$(database)/documents/devices/$(senderDeviceId)).data.ownerUid == request.auth.uid;
    }

    function isPendingRequestStatus(status) {
      return status == 'pending';
    }

    function isTerminalRequestStatus(status) {
      return status == 'accepted' || status == 'declined' || status == 'expired';
    }

    // Message timestamp must be close to server time to reduce spoofing/replay.
    // Tolerance: ±5 minutes to accommodate device clock skew (NTP drift, airplane mode, etc.)
    // Previous +60s future limit was too tight — devices with clocks 2min ahead had ALL writes rejected.
    function isRecentClientTimestamp(ts) {
      return ts is number
             && ts <= request.time.toMillis() + 300000
             && ts >= request.time.toMillis() - 300000;
    }

    function isValidLatitude(latitude) {
      return latitude is number && latitude >= -90 && latitude <= 90;
    }

    function isValidLongitude(longitude) {
      return longitude is number && longitude >= -180 && longitude <= 180;
    }

    function isValidBatteryPercent(value) {
      return value == null || (value is number && value >= 0 && value <= 100);
    }

    function isValidCurrentLocationWrite(userId) {
      return isOwner(userId)
             && isValidLatitude(request.resource.data.latitude)
             && isValidLongitude(request.resource.data.longitude)
             && !(request.resource.data.latitude == 0 && request.resource.data.longitude == 0)
             && (!('userId' in request.resource.data) || request.resource.data.userId == userId)
             && (!('deviceId' in request.resource.data) || request.resource.data.deviceId is string)
             && (!('timestamp' in request.resource.data) || isRecentClientTimestamp(request.resource.data.timestamp))
             && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is number)
             && (!('battery' in request.resource.data) || isValidBatteryPercent(request.resource.data.battery))
             && (!('batteryLevel' in request.resource.data) || isValidBatteryPercent(request.resource.data.batteryLevel))
             && (!('batteryUpdatedAt' in request.resource.data) || request.resource.data.batteryUpdatedAt == null || request.resource.data.batteryUpdatedAt is number)
             && (!('source' in request.resource.data) || request.resource.data.source in ['gps', 'network', 'manual']);
    }

    // Basic per-conversation throttle: same sender cannot post back-to-back in <700ms.
    //
    // M5 (typing-indicator exemption): TYPING signals fire on every keystroke
    // and would trip this 700ms guard during fast typing or emoji bursts. We
    // exempt them by checking the incoming `type` field. Anything that ISN'T
    // a TYPING signal still pays the 700ms cost, so the abuse-protection
    // properties of the throttle remain intact for actual messages.
    //
    // Why type-check is safe: rules can't be bypassed by spoofing `type` —
    // even a malicious client labelling spam as TYPING still has to satisfy
    // per-message create rules (recipient inbox bound, sender = auth.uid).
    // The worst they can do is bypass rate-limit on typing notifications,
    // which carry no payload — already low-impact.
    function passesConversationMessageRateLimit(conversationId) {
      let conversation = get(/databases/$(database)/documents/conversations/$(conversationId)).data;
      let isTypingSignal = request.resource.data.type == 'TYPING';
      return isTypingSignal
             || !(conversation.lastMessage is map)
             || !(conversation.lastMessage.from is string)
             || !(conversation.lastMessage.timestamp is number)
             || conversation.lastMessage.from != request.auth.uid
             || request.resource.data.timestamp >= conversation.lastMessage.timestamp + 700;
    }

    // Optional server-side block switch:
    // Cloud Functions may set rate_limits/{uid}.messagingBlockedUntil (epoch ms).
    function notBlockedByServerMessageRateLimit() {
      return !exists(/databases/$(database)/documents/rate_limits/$(request.auth.uid))
             || !(get(/databases/$(database)/documents/rate_limits/$(request.auth.uid)).data.messagingBlockedUntil is number)
             || request.time.toMillis() > get(/databases/$(database)/documents/rate_limits/$(request.auth.uid)).data.messagingBlockedUntil;
    }

    function notBlockedByServerSosRateLimit() {
      return !exists(/databases/$(database)/documents/rate_limits/$(request.auth.uid))
             || !(get(/databases/$(database)/documents/rate_limits/$(request.auth.uid)).data.sosBlockedUntil is number)
             || request.time.toMillis() > get(/databases/$(database)/documents/rate_limits/$(request.auth.uid)).data.sosBlockedUntil;
    }

    function isConversationParticipant(conversationId) {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/conversations/$(conversationId))
             && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants is list
             && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    function isConversationMessageReceiptUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'readBy',
               'deliveredTo',
               'updatedAt'
             ])
             && (
               !changed.hasAny(['readBy'])
               || (
                 request.resource.data.readBy is map
                 && (!(resource.data.readBy is map) || request.resource.data.readBy.diff(resource.data.readBy).affectedKeys().hasOnly([request.auth.uid]))
                 && ((resource.data.readBy is map) || request.resource.data.readBy.keys().hasOnly([request.auth.uid]))
               )
             )
             && (
               !changed.hasAny(['deliveredTo'])
               || (
                 request.resource.data.deliveredTo is map
                 && (!(resource.data.deliveredTo is map) || request.resource.data.deliveredTo.diff(resource.data.deliveredTo).affectedKeys().hasOnly([request.auth.uid]))
                 && ((resource.data.deliveredTo is map) || request.resource.data.deliveredTo.keys().hasOnly([request.auth.uid]))
               )
             );
    }

    function isConversationMessageSenderUpdate() {
      return resource.data.senderUid == request.auth.uid
             && request.resource.data.senderUid == resource.data.senderUid
             && request.resource.data.timestamp == resource.data.timestamp
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'content',
               'isEdited',
               'editedAt',
               'deleted',
               'deletedAt',
               'updatedAt'
             ])
             && (!('content' in request.resource.data)
                 || (request.resource.data.content is string
                     && request.resource.data.content.size() <= 5000));
    }

    function isConversationMetadataTimestamp(value) {
      return value is number || value is timestamp;
    }

    function keepsConversationImmutableFields() {
      return request.resource.data.participants == resource.data.participants
             && (
               (!('createdAt' in resource.data) && !('createdAt' in request.resource.data))
               || request.resource.data.createdAt == resource.data.createdAt
             )
             && (
               (!('createdBy' in resource.data) && !('createdBy' in request.resource.data))
               || request.resource.data.createdBy == resource.data.createdBy
             )
             && (
               (!('type' in resource.data) && !('type' in request.resource.data))
               || request.resource.data.type == resource.data.type
             )
             && (
               (!('pairKey' in resource.data) && !('pairKey' in request.resource.data))
               || request.resource.data.pairKey == resource.data.pairKey
             );
    }

    function isConversationMetadataUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return keepsConversationImmutableFields()
             && changed.hasOnly([
               'lastMessage',
               'lastMessagePreview',
               'lastMessageSenderName',
               'lastMessageSenderUid',
               'lastMessageAt',
               'updatedAt'
             ])
             && (!changed.hasAny(['lastMessage'])
                 || (request.resource.data.lastMessage is string
                     && request.resource.data.lastMessage.size() <= 5000))
             && (!changed.hasAny(['lastMessagePreview'])
                 || (request.resource.data.lastMessagePreview is string
                     && request.resource.data.lastMessagePreview.size() <= 500))
             && (!changed.hasAny(['lastMessageSenderName'])
                 || (request.resource.data.lastMessageSenderName is string
                     && request.resource.data.lastMessageSenderName.size() <= 120))
             && (!changed.hasAny(['lastMessageSenderUid'])
                 || request.resource.data.lastMessageSenderUid == request.auth.uid)
             && (!changed.hasAny(['lastMessageAt'])
                 || isConversationMetadataTimestamp(request.resource.data.lastMessageAt))
             && (!changed.hasAny(['updatedAt'])
                 || isConversationMetadataTimestamp(request.resource.data.updatedAt));
    }

    function isConversationTypingUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return keepsConversationImmutableFields()
             && changed.hasOnly(['typing'])
             && (
               (
                 request.resource.data.typing is map
                 && (
                   (!(resource.data.typing is map)
                    && request.resource.data.typing.keys().hasOnly([request.auth.uid]))
                   || (
                     resource.data.typing is map
                     && request.resource.data.typing.diff(resource.data.typing).affectedKeys().hasOnly([request.auth.uid])
                   )
                 )
               )
               || (
                 !('typing' in request.resource.data)
                 && resource.data.typing is map
                 && resource.data.typing.keys().hasOnly([request.auth.uid])
               )
             );
    }

    function isConversationGroupProfileUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return resource.data.type == 'group'
             && resource.data.createdBy == request.auth.uid
             && keepsConversationImmutableFields()
             && changed.hasOnly([
               'name',
               'avatarUrl',
               'updatedAt'
             ])
             && (!changed.hasAny(['name'])
                 || (request.resource.data.name is string
                     && request.resource.data.name.size() <= 120))
             && (!changed.hasAny(['avatarUrl'])
                 || request.resource.data.avatarUrl == null
                 || (request.resource.data.avatarUrl is string
                     && request.resource.data.avatarUrl.size() <= 2048))
             && (!changed.hasAny(['updatedAt'])
                 || isConversationMetadataTimestamp(request.resource.data.updatedAt));
    }

    function isConversationMembershipUpdate() {
      return resource.data.type == 'group'
             && resource.data.createdBy == request.auth.uid
             && request.resource.data.type == resource.data.type
             && request.resource.data.createdBy == resource.data.createdBy
             && request.resource.data.createdAt == resource.data.createdAt
             && request.resource.data.participants is list
             && request.auth.uid in request.resource.data.participants
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'participants',
               'participantNames',
               'participantDeviceIds',
               'updatedAt'
             ]);
    }

    function isValidPublicUserProfileData(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 80))
             && (!('photoURL' in data) || (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048)))
             && (!('qrId' in data) || (data.qrId is string && data.qrId.size() <= 64))
             && (!('deviceId' in data) || (data.deviceId is string && data.deviceId.size() <= 128))
             && (!('publicUserCode' in data) || (data.publicUserCode is string && data.publicUserCode.size() <= 64))
             && (!('primaryDeviceId' in data) || (data.primaryDeviceId is string && data.primaryDeviceId.size() <= 128))
             && (!('status' in data) || data.status in ['safe', 'needs_help', 'trapped', 'sos', 'offline', 'need-help', 'unknown', 'critical']);
    }

    // NOTE: isNewsSummaryJobOwner, hasAppCheck, isNotSpamming removed — unused
    
    // ============================================================
    // EEW COLLECTIONS - Elite Security
    // ============================================================
    
    // P-wave crowdsourced detections
    // SECURITY FIX: userId must match auth.uid to prevent spoofing
    // Rate limited, auto-expires after 5 minutes
    match /eew_pwave_detections/{detectionId} {
      // SECURITY NOTE: Read is open to authenticated users because the client needs
      // to query nearby P-wave detections for crowdsourced earthquake consensus.
      // FirebaseEEWOperations.getNearbyDetections() fetches recent detections and
      // filters by geo-proximity client-side. Restricting to own userId would break
      // the consensus detection feature. The query is already limited (50 docs, 5min).
      // Location data exposure is mitigated by short TTL (detections expire in 5min).
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.deviceId is string
                    && request.resource.data.timestamp is number
                    && isRecentClientTimestamp(request.resource.data.timestamp)
                    && request.resource.data.latitude is number
                    && request.resource.data.latitude >= -90
                    && request.resource.data.latitude <= 90
                    && request.resource.data.longitude is number
                    && request.resource.data.longitude >= -180
                    && request.resource.data.longitude <= 180
                    && request.resource.data.accuracy is number
                    && request.resource.data.accuracy >= 0
                    && request.resource.data.accuracy <= 10000
                    && request.resource.data.magnitude is number
                    && request.resource.data.magnitude >= 0
                    && request.resource.data.magnitude <= 5
                    && request.resource.data.frequency is number
                    && request.resource.data.frequency >= 0
                    && request.resource.data.frequency <= 100
                    && request.resource.data.staltaRatio is number
                    && request.resource.data.staltaRatio >= 0
                    && request.resource.data.staltaRatio <= 1000
                    && request.resource.data.confidence is number
                    && request.resource.data.confidence >= 0
                    && request.resource.data.confidence <= 100;
      allow update: if false;
      allow delete: if false;
    }
    
    // EEW broadcasts (official or crowdsourced)
    // SECURITY FIX: Only Cloud Functions (admin SDK) can create broadcasts
    // Prevents any authenticated user from creating fake earthquake alerts
    //
    // H2/H3 (public-read documentation): `allow read: if true` is INTENTIONAL.
    //   - EEW alerts are public-safety data; we want unauthenticated devices
    //     (e.g. pre-login bootstrap, kiosk mode) to receive them.
    //   - Risk: scrape-ability of historical broadcasts. Mitigated by:
    //       a) Firebase default per-IP rate limit (~50 read/s)
    //       b) Documents only contain alert metadata, not user data
    //       c) Document IDs are time-ordered → forward enumeration limited
    //   - v2.0 migration plan: move public reads to a Cloud Functions HTTP
    //     endpoint with edge-cache (Cloud CDN) + per-IP rate limit + abuse
    //     monitoring. Tracking issue: see docs/SECURITY_HARDENING_v2.md.
    match /eew_broadcasts/{broadcastId} {
      allow read: if true;
      allow create: if false; // Only via Cloud Functions with admin SDK
      allow update: if false; // Only via Cloud Functions with admin SDK
      allow delete: if isAdmin();
    }
    
    // EEW history (user-specific)
    // - Only owner can read/write
    match /eew_history/{entryId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.timestamp is number;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // P-wave consensus (aggregated data)
    // SECURITY FIX: Only Cloud Functions can write consensus data
    // Prevents manipulation of consensus thresholds from client
    //
    // H2/H3 (public-read documentation): public read is intentional — clients
    // poll consensus to know whether to trigger their own EEW. Same scrape
    // risk profile as eew_broadcasts; same v2.0 mitigation plan applies.
    match /eew_consensus/{consensusId} {
      allow read: if true;
      allow create: if false; // Only via Cloud Functions with admin SDK
      allow update: if false; // Only via Cloud Functions with admin SDK
      allow delete: if false; // Only via Cloud Functions with admin SDK
    }
    
    // EEW analytics (write-only for tracking)
    // - Anyone authenticated can write
    // - No reads (only Cloud Functions)
    match /eew_analytics/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.eventType is string
                    && request.resource.data.timestamp is number;
      allow update: if false;
      allow delete: if false;
    }
    
    // ============================================================
    // DEVICES COLLECTION - ELITE FAMILY TRACKING
    // ============================================================
    
    // Device documents store user's device info and current location
    // - Owner can read/write their own device
    // - Family members can read device location for tracking (via deviceId field match)
    // CRITICAL: Restrict to device owner via qrId matching
    match /devices/{deviceId} {
      // ELITE SECURITY: Owner or explicitly linked family member only
      allow read: if isDeviceReadable(deviceId);

      // First write must bind ownerUid to authenticated user
      allow create: if isAuthenticated()
                    && request.resource.data.ownerUid == request.auth.uid;

      // Owner-only updates; ownerUid cannot be changed after creation.
      // SECURITY: "migration-safe claim" dalı kaldırıldı — ownerUid'si string
      // olmayan legacy doküman herhangi bir kullanıcı tarafından ele geçirilebiliyordu
      // (aile konumu/SOS/mesaj erişimi hijack riski). Legacy doküman migrasyonu
      // admin SDK (Cloud Function) ile yapılır; rules'ı bypass eder.
      allow update: if isDeviceOwner(deviceId)
                    && request.resource.data.ownerUid == resource.data.ownerUid;
      // CRITICAL FIX: Allow device owner to delete (account deletion / GDPR)
      allow delete: if isDeviceOwner(deviceId);
      
      // Family members subcollection
      // - Each device can have its own family members list
      // CRITICAL FIX: Allow any authenticated user to CREATE family member entries.
      // This enables reciprocal linking: when User A adds User B, the app writes
      // a link-back doc at devices/{B}/familyMembers/{A} so that isLinkedFamilyMember()
      // succeeds in BOTH directions (required for location/status/message reads).
      match /familyMembers/{memberId} {
        allow read: if isDeviceReadable(deviceId);
        // SECURITY FIX: Only device owner can add family members to their device.
        // Previously allowed any user to add themselves — enabling unauthorized device linking.
        allow create: if isDeviceOwner(deviceId)
                      && request.resource.data.id is string;
        allow update: if isDeviceOwner(deviceId);
        // Allow device owner to delete any member, OR allow a user to delete
        // their own reciprocal doc (memberId matches their uid or qrId).
        // This enables clean reciprocal cleanup when unfriending.
        allow delete: if isDeviceOwner(deviceId)
                      || request.auth.uid == memberId
                      || requesterQrId() == memberId;
      }
      
      // Location history subcollection
      match /locations/{locationId} {
        allow read: if isDeviceReadable(deviceId);
        allow create: if isDeviceOwner(deviceId)
                      && request.resource.data.latitude is number
                      && request.resource.data.longitude is number;
        allow update: if isDeviceOwner(deviceId)
                      && request.resource.data.latitude is number
                      && request.resource.data.longitude is number;
        allow delete: if false; // Cleanup via Cloud Functions/TTL
      }
      
      // Status updates subcollection
      match /status/{statusId} {
        allow read: if isDeviceReadable(deviceId);
        allow create: if isDeviceOwner(deviceId);
        allow update: if isDeviceOwner(deviceId);
        allow delete: if false;
      }

      // Status updates from family members (fan-out writes)
      // Only device owner or linked family members can write status updates
      match /status_updates/{updateId} {
        allow read: if isDeviceReadable(deviceId);
        allow create: if (isDeviceOwner(deviceId) || isLinkedFamilyMember(deviceId))
                      && request.resource.data.fromDeviceId is string
                      && request.resource.data.status is string
                      && request.resource.data.timestamp is number;
        allow update: if false;
        allow delete: if isDeviceOwner(deviceId);
      }
      
      // Health profile subcollection
      match /health/{healthId} {
        allow read: if isDeviceOwner(deviceId);
        allow create: if isDeviceOwner(deviceId);
        allow update: if isDeviceOwner(deviceId);
        allow delete: if false;
      }
      
      // ICE (In Case of Emergency) data subcollection
      match /ice/{iceId} {
        allow read: if isDeviceOwner(deviceId);
        allow create: if isDeviceOwner(deviceId);
        allow update: if isDeviceOwner(deviceId);
        allow delete: if false;
      }
      
      // Messages subcollection  
      match /messages/{messageId} {
        // CRITICAL FIX: Allow family members to read messages (not just device owner)
        // Without this, messages sent via cloud fan-out cannot be read by recipients
        allow read: if isDeviceReadable(deviceId);
        // SECURITY: Any authenticated user can create messages in any device inbox
        // (fan-out write pattern: sender writes to recipient's inbox)
        // Validation: fromDeviceId and toDeviceId must be strings, content must exist
        // SECURITY FIX: senderUid is MANDATORY and must match auth.uid to prevent spoofed messages
        allow create: if isAuthenticated()
                      && request.resource.data.fromDeviceId is string
                      && request.resource.data.toDeviceId is string
                      && request.resource.data.content is string
                      && request.resource.data.senderUid is string
                      && request.resource.data.senderUid == request.auth.uid;
        // CRITICAL FIX: Allow owner OR message sender to update messages.
        // Owner: for read receipts, status updates on own inbox.
        // Sender (isSenderOwned): for retries — setDoc({merge:true}) on an
        // existing doc triggers UPDATE, not CREATE. Without this, all
        // retries to recipient inboxes silently fail with permission-denied.
        allow update: if isDeviceOwner(deviceId)
                      || (isAuthenticated()
                          && resource.data.fromDeviceId is string
                          && isSenderOwned(resource.data.fromDeviceId));
        // Device owner can delete messages from their inbox (cleanup)
        allow delete: if isDeviceOwner(deviceId);
      }
      
      // Conversations subcollection
      match /conversations/{conversationId} {
        allow read: if isDeviceOwner(deviceId);
        // CRITICAL FIX: Allow any authenticated user to create conversations
        // (fan-out: sender creates conversation metadata in recipient's device)
        // SECURITY FIX: Creator must be a participant in the conversation
        allow create: if isAuthenticated()
                      && request.resource.data.participants is list
                      && request.auth.uid in request.resource.data.participants;
        allow update: if isDeviceOwner(deviceId);
        allow delete: if isDeviceOwner(deviceId);
      }

      // NOTE: status_updates rules are defined above (lines 206-216) — no duplicate needed

      // SOS Alerts subcollection (CRITICAL: Life-saving)
      // - Any authenticated user can CREATE an SOS alert for any device
      //   (family member sends SOS to your device path)
      // - Device owner + linked family can READ alerts
      // SECURITY FIX: senderUid is MANDATORY and must match auth.uid to prevent SOS spoofing
      match /sos_alerts/{alertId} {
        allow read: if isDeviceReadable(deviceId);
        allow create: if isAuthenticated()
                      && (isDeviceOwner(deviceId) || isLinkedFamilyMember(deviceId))
                      && request.resource.data.signalId is string
                      && request.resource.data.timestamp is number
                      && isRecentClientTimestamp(request.resource.data.timestamp)
                      && request.resource.data.senderUid is string
                      && request.resource.data.senderUid == request.auth.uid;
        // CRITICAL FIX: Allow SOS sender to update (cancel) their own alerts on any device.
        // Previously only device owner could update → SOS cancellation to family SILENTLY FAILED.
        allow update: if isDeviceOwner(deviceId)
                      || (isAuthenticated() && resource.data.senderUid == request.auth.uid);
        allow delete: if isDeviceOwner(deviceId);
      }

      // SOS Rescue ACKs subcollection (CRITICAL: Life-saving)
      // When rescuer taps "Geliyorum", an ACK is written here.
      // The SOS sender's SOSAckListener watches this path.
      // - Any authenticated user can CREATE (rescuers may not be in family)
      // - Device owner + family can READ (SOS sender sees help coming)
      match /sos_acks/{ackId} {
        allow read: if isDeviceReadable(deviceId);
        allow create: if isAuthenticated()
                      && request.resource.data.timestamp is number
                      && request.resource.data.userId is string
                      && request.resource.data.userId == request.auth.uid
                      && (!('rescuerUid' in request.resource.data)
                          || request.resource.data.rescuerUid == request.auth.uid);
        allow update: if false; // ACKs are immutable
        allow delete: if isDeviceOwner(deviceId); // Cleanup only
      }

      // Earthquake alerts subcollection (device-specific alert history)
      match /earthquakeAlerts/{alertId} {
        allow read, delete: if isDeviceOwner(deviceId);
      }
    }
    
    // ============================================================
    // SEISMIC DETECTIONS - Crowdsourced Data
    // ============================================================
    
    match /seismicDetections/{detectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.deviceId is string
                    && request.resource.data.latitude is number
                    && request.resource.data.longitude is number
                    && request.resource.data.userId == request.auth.uid
                    && isRecentClientTimestamp(request.resource.data.timestamp);
      // SECURITY: Sismik tespit kaydı immutable — bir kez yazılır, değişmez.
      // Aksi halde sahibi koordinat/büyüklük değerlerini sonradan değiştirip
      // crowdsourced veri bütünlüğünü bozabilirdi (plum_observations ile tutarlı).
      allow update: if false;
      allow delete: if false;
    }
    
    // ============================================================
    // NEW: FCM TOKEN MANAGEMENT
    // ============================================================
    
    // FCM tokens (user-specific)
    // - Only owner can read/write their token
    // - Token registration is required for push notifications
    match /fcm_tokens/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
                            && request.resource.data.token is string
                            && request.resource.data.platform is string;
      allow delete: if isOwner(userId);
      
      // FIX #7: Multi-device FCM token subcollection
      match /devices/{deviceId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
                              && request.resource.data.token is string
                              && request.resource.data.platform is string;
        allow delete: if isOwner(userId);
      }
    }
    
    // ============================================================
    // NEW: PLUM OBSERVATIONS (Elite EEW)
    // ============================================================
    
    // PLUM intensity observations for proximity-based EEW
    // - Public read for P2P sharing
    // - Authenticated create
    match /plum_observations/{observationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.deviceId is string
                    && request.resource.data.latitude is number
                    && request.resource.data.latitude >= -90
                    && request.resource.data.latitude <= 90
                    && request.resource.data.longitude is number
                    && request.resource.data.longitude >= -180
                    && request.resource.data.longitude <= 180
                    && request.resource.data.intensity is number
                    && request.resource.data.timestamp is number;
      allow update: if false;
      allow delete: if false; // Cleanup via TTL or Cloud Functions
    }
    
    // ============================================================
    // NEW: EEW EVENTS (Server-Side Generated)
    // ============================================================
    
    // EEW events from official sources (AFAD, Kandilli, etc.)
    // - Public read
    // - Only Cloud Functions can write (via admin SDK)
    //
    // H2/H3 (public-read documentation): identical rationale to eew_broadcasts —
    // public-safety feed must be reachable pre-login. v2.0: migrate to CF HTTP +
    // CDN + per-IP rate limit.
    match /eew_events/{eventId} {
      allow read: if true;
      allow write: if false; // Only via Cloud Functions with admin SDK
    }
    
    // ============================================================
    // PREPAREDNESS PLANS - User-Owned Plans
    // ============================================================
    
    // Preparedness plans generated by AI or rule-based fallback
    // - Only the plan owner can read/write
    // - Plans contain personalized disaster preparation checklists
    match /preparedness_plans/{planId} {
      allow read: if isAuthenticated()
                  && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if false; // Plans should be preserved
    }
    
    // ============================================================
    // NEW: DAILY ANALYTICS (Aggregated)
    // ============================================================
    
    // Daily analytics summaries
    // - Admin only read
    // - Only Cloud Functions can write
    match /eew_analytics_daily/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Only via Cloud Functions
    }
    
    // ============================================================
    // NEWS SUMMARIES - SHARED CACHE (Cost Optimization)
    // ============================================================
    
    // News summaries (shared across ALL users for cost optimization)
    // SECURITY FIX: Only Cloud Functions can write summaries
    // Prevents poisoning of shared AI summaries consumed by all users
    // Client creates summary jobs, Cloud Function generates and writes the summary
    match /news_summaries/{summaryId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only via Cloud Functions with admin SDK
    }

    // Summary generation leases (single-writer lock per article)
    match /news_summary_jobs/{summaryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.articleId is string
                    && request.resource.data.articleId == summaryId
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.status == 'processing'
                    && request.resource.data.leaseUntil is number;
      allow update: if isAuthenticated()
                    && request.resource.data.articleId is string
                    && request.resource.data.articleId == summaryId
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.status is string
                    // SECURITY: leaseUntil en fazla 10 dk ileri olabilir — lock
                    // sahibi kilidi sonsuza uzatıp başkalarını kalıcı bloklayamaz.
                    && request.resource.data.leaseUntil is number
                    && request.resource.data.leaseUntil <= request.time.toMillis() + 600000
                    && (
                      // Current lock owner can update lifecycle state.
                      resource.data.ownerUid == request.auth.uid
                      // Expired lock can be taken over by another authenticated user.
                      || (
                        resource.data.leaseUntil is number
                        && resource.data.leaseUntil < request.time.toMillis()
                      )
                    );
      allow delete: if false;
    }

    // K2: Monitoring collection — CF-only writes (admin SDK bypasses rules).
    // Used by Kandilli parser health tracking. Reads restricted to admins so
    // counters don't leak operational signals to clients.
    match /monitoring/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions admin SDK only
    }

    // ============================================================
    // EXISTING COLLECTIONS (if not already defined)
    // ============================================================

    // Users collection
    match /users/{userId} {
      // V3: Tekil profil okuma mesajlaşma için gereklidir.
      // SECURITY: list/query yalnızca admin — açık list tüm kullanıcı tabanını
      // (qrId, displayName, status) dökebilirdi. İstemci tekil get kullanır.
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasOnly([
                      'displayName',
                      'photoURL',
                      'qrId',
                      'deviceId',
                      'publicUserCode',
                      'primaryDeviceId',
                      'primaryDeviceUpdatedAt',
                      'status',
                      'createdAt',
                      'updatedAt',
                      'lastSeen'
                    ])
                    && isValidPublicUserProfileData(request.resource.data);
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'displayName',
                      'photoURL',
                      'qrId',
                      'deviceId',
                      'publicUserCode',
                      'primaryDeviceId',
                      'primaryDeviceUpdatedAt',
                      'status',
                      'createdAt',
                      'updatedAt',
                      'lastSeen',
                      'email',
                      'lastLoginAt'
                    ])
                    && isValidPublicUserProfileData(request.resource.data)
                    && !('email' in request.resource.data)
                    && !('lastLoginAt' in request.resource.data);
      // CRITICAL FIX: Allow owner to delete their own profile (account deletion / GDPR)
      allow delete: if isOwner(userId);

      // Private contacts for each authenticated user
      match /contacts/{contactId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // Private block list for each authenticated user
      match /blocked/{blockedId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // Private reactions mirror for each authenticated user
      match /reactions/{reactionId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // Contact requests inbox.
      match /contactRequests/{requestId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated()
                      && request.auth.uid == requestId
                      && request.resource.data.fromUserId == request.auth.uid
                      && request.resource.data.toUserId == userId
                      && request.resource.data.status is string
                      && isPendingRequestStatus(request.resource.data.status)
                      && request.resource.data.fromQrId is string
                      && request.resource.data.fromName is string;
        allow update: if (
                        isOwner(userId)
                        && resource.data.fromUserId is string
                        && request.resource.data.fromUserId == resource.data.fromUserId
                        && request.resource.data.status is string
                        && isTerminalRequestStatus(request.resource.data.status)
                      ) || (
                        isAuthenticated()
                        && request.auth.uid == requestId
                        && request.resource.data.fromUserId == request.auth.uid
                        && request.resource.data.toUserId == userId
                        && request.resource.data.status is string
                        && isPendingRequestStatus(request.resource.data.status)
                      );
        allow delete: if isOwner(userId);
      }

      // Per-user notifications inbox.
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isAuthenticated()
                      && request.resource.data.type is string
                      && request.resource.data.fromUserId is string
                      && request.resource.data.fromUserId == request.auth.uid;
      }

      // V3: Health profile subcollection (moved from devices/{id}/health)
      match /health/{healthId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId); // GDPR: owner can delete
      }

      // V3: ICE data subcollection (moved from devices/{id}/ice)
      match /ice/{iceId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId); // GDPR: owner can delete
      }

      // V3: Status subcollection
      match /status/{statusId} {
        allow read: if isOwner(userId) || sharesFamilyWith(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId); // GDPR: owner can delete
      }

      // V3: Status updates history
      // NOTE: Family members write status updates to EACH OTHER's subcollections
      // (FamilyScreen.handleStatusUpdate fans out to all members' paths)
      // SECURITY FIX: senderUid must match auth.uid to prevent spoofed status updates
      match /status_updates/{updateId} {
        allow read: if isOwner(userId) || sharesFamilyWith(userId);
        allow create: if isAuthenticated()
                      && (isOwner(userId) || sharesFamilyWith(userId))
                      && request.resource.data.timestamp is number
                      && request.resource.data.senderUid is string
                      && request.resource.data.senderUid == request.auth.uid;
        allow update: if false;
        allow delete: if isOwner(userId); // GDPR: owner can delete their own history
      }

      // V3: Bidirectional family member mapping (used by sharesFamilyWith() rule function)
      // Written by: saveFamilyMember (both directions), deleted by: deleteFamilyMember
      // Read by: sharesFamilyWith() via exists() check
      match /familyMembers/{otherUid} {
        allow read: if isOwner(userId)
                    || (request.auth.uid == otherUid && sharesFamilyWith(userId));
        // Pending links are invitation metadata only. Live data access requires both
        // directions to become approvalState='mutual' after an accepted contact request.
        allow create: if isAuthenticated()
                      && userId != otherUid
                      && (
                        isPendingFamilyLinkWrite(userId, otherUid)
                        || isAcceptedFamilyLinkWrite(userId, otherUid)
                      );
        allow update: if isAuthenticated()
                      && userId != otherUid
                      && (
                        isPendingFamilyLinkWrite(userId, otherUid)
                        || isAcceptedFamilyLinkWrite(userId, otherUid)
                      );
        allow delete: if isOwner(userId)
                      || request.auth.uid == otherUid; // Either side can remove mapping
      }

      // V3: UID → familyId mapping (for security rule lookups)
      // SECURITY FIX: Only owner can read/write their own familyId mappings
      match /familyIds/{familyId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // V3: User settings (cross-device sync)
      // Only the owner can read/write their own settings
      match /settings/{settingId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if isOwner(userId); // GDPR: owner can delete
      }
    }
    
    // Earthquakes collection (read-only for users, write via Cloud Functions)
    //
    // H2/H3 (public-read documentation): public read by design — earthquake
    // catalog must work for unauthenticated/pre-login views (e.g. cold-start
    // map). Firebase per-IP rate limit (50 r/s) gates abuse. v2.0 plan:
    // migrate to a CF HTTP endpoint with edge cache, allowing per-IP token
    // bucket + WAF rules. Tracking: docs/SECURITY_HARDENING_v2.md.
    match /earthquakes/{earthquakeId} {
      allow read: if true;
      // ELITE SECURITY: Users cannot write earthquakes - only Cloud Functions with admin SDK
      allow write: if false;
    }
    
    // Felt earthquakes reports
    // SECURITY FIX: userId must match auth.uid to prevent spoofing
    match /feltEarthquakes/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.earthquakeId is string
                    && request.resource.data.timestamp is number;
      allow update: if false;
      allow delete: if false;
    }
    
    // Global earthquakes (read-only for users, write via Cloud Functions)
    match /global_earthquakes/{earthquakeId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Family members (top-level collection)
    // ELITE SECURITY: Restrict to users who own the linked device
    match /familyMembers/{memberId} {
      allow read: if isAuthenticated() 
                  && (resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() 
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() 
                    && resource.data.ownerUid == request.auth.uid;
      allow delete: if isAuthenticated() 
                    && resource.data.ownerUid == request.auth.uid;
    }
    
    // SOS alerts (legacy)
    // SECURITY FIX: senderUid is MANDATORY and must match auth.uid to prevent SOS spoofing
    // PRIVACY FIX: Only admin or the SOS sender can read legacy SOS alerts
    match /sosAlerts/{alertId} {
      allow read: if isAdmin()
                  || (isAuthenticated() && resource.data.senderUid == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.senderUid is string
                    && request.resource.data.senderUid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }
    
    // Messages
    match /messages/{messageId} {
      allow read: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    
    // ============================================================
    // GLOBAL SOS SIGNALS (Firebase SOS backup record)
    // Life-saving: Any authenticated user can create their own SOS signal
    // SECURITY: Only the creator can read their own SOS signals — prevents
    // enumeration of all SOS signals by any authenticated user
    // ============================================================

    match /sos_signals/{signalId} {
      allow read: if isAuthenticated() && resource.data.creatorUid == request.auth.uid;
      // ANTI-ABUSE: Timestamp must be recent (within 5 min) to prevent replay attacks
      allow create: if isAuthenticated()
                    && request.resource.data.id is string
                    && request.resource.data.timestamp is number
                    && isRecentClientTimestamp(request.resource.data.timestamp)
                    && request.resource.data.status is string
                    && request.resource.data.creatorUid == request.auth.uid
                    && notBlockedByServerSosRateLimit();
      allow update: if isAuthenticated()
                    && resource.data.creatorUid == request.auth.uid
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.creatorUid == resource.data.creatorUid;
      // GDPR: creator can delete their own SOS signals during account deletion
      allow delete: if isAuthenticated() && resource.data.creatorUid == request.auth.uid;
    }

    // ============================================================
    // V3: PUSH TOKENS — UID-Centric Push Notification Tokens
    // Path: push_tokens/{uid}/devices/{installationId}
    // ============================================================

    match /push_tokens/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /devices/{installationId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
                              && request.resource.data.token is string;
        allow delete: if isOwner(userId);
      }
    }

    // ============================================================
    // V3: LOCATIONS CURRENT — Single Document Per User
    // Path: locations_current/{uid}
    // Owner can write, family members can read
    // ============================================================

    match /locations_current/{userId} {
      // SECURITY FIX: Only owner or family members can read location
      // Previously ANY authenticated user could read ANY user's real-time location
      allow read: if isOwner(userId) || sharesFamilyWith(userId);
      allow create, update: if isValidCurrentLocationWrite(userId);
      allow delete: if isOwner(userId); // GDPR: owner can delete their location
    }

    // V3: Location history trail
    match /locations_history/{userId} {
      allow read: if isOwner(userId);
      allow delete: if isOwner(userId); // GDPR: owner can delete

      match /points/{pointId} {
        allow read: if isOwner(userId);
        allow create: if isValidCurrentLocationWrite(userId);
        allow update: if false;
        allow delete: if isOwner(userId); // GDPR: owner can delete
      }
    }

    // ============================================================
    // V3: FAMILIES — Family Groups
    // Path: families/{familyId}/members/{uid}
    // ============================================================

    match /families/{familyId} {
      // Any member can read family metadata
      allow read: if isAuthenticated()
                  && (
                    (
                      resource.data.members is list
                      && request.auth.uid in resource.data.members
                    )
                    || hasMutualFamilyLink(resource.data.createdBy, request.auth.uid)
                  );
      // Any authenticated user can create a family (creator becomes admin)
      allow create: if isAuthenticated()
                    && request.resource.data.members is list
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.createdBy == request.auth.uid;
      // WP-5.16: Tam üye-düzeyi yetkilendirme.
      // members listesi değişmemişse: herhangi bir üye metadata güncelleyebilir.
      // members listesi değişiyorsa iki senaryo meşrudur:
      //   1. Kurucu (createdBy) — istediği üyeyi ekleyip çıkarabilir.
      //   2. Kullanıcı YALNIZCA kendi üyeliğini değiştiriyorsa (katılma / ayrılma):
      //      Her iki listeden auth.uid çıkarılınca eşitlerse, başka hiçbir üyeye
      //      dokunulmamış demektir.
      // createdBy her durumda immutable; kurucu her zaman listede kalmalıdır.
      allow update: if isAuthenticated()
                    && resource.data.members is list
                    && request.resource.data.members is list
                    && request.auth.uid in resource.data.members
                    && request.resource.data.createdBy == resource.data.createdBy
                    && resource.data.createdBy in request.resource.data.members
                    && (
                      // members listesi hiç değişmedi — metadata güncellemesi
                      request.resource.data.members == resource.data.members
                      // Kurucu tüm listeyi yönetebilir
                      || request.auth.uid == resource.data.createdBy
                      // Kullanıcı yalnızca kendi üyeliğini değiştiriyor
                      || request.resource.data.members.removeAll([request.auth.uid])
                         == resource.data.members.removeAll([request.auth.uid])
                    );
      // GDPR: creator can delete family during account deletion
      allow delete: if isAuthenticated()
                    && resource.data.createdBy == request.auth.uid;

      // Family members subcollection
      match /members/{memberUid} {
        allow read: if isAuthenticated()
                    && (
                      (
                        get(/databases/$(database)/documents/families/$(familyId)).data.members is list
                        && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members
                      )
                      || hasMutualFamilyLink(get(/databases/$(database)/documents/families/$(familyId)).data.createdBy, request.auth.uid)
                    );
        // Existing members can add records; accepted invitees can create their own record.
        allow create: if isAuthenticated()
                      && request.resource.data.uid is string
                      && exists(/databases/$(database)/documents/families/$(familyId))
                      && (
                        request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members
                        || (
                          request.auth.uid == memberUid
                          && hasMutualFamilyLink(get(/databases/$(database)/documents/families/$(familyId)).data.createdBy, memberUid)
                        )
                      );
        // Only the member themselves or family admin can update
        allow update: if isAuthenticated()
                      && (request.auth.uid == memberUid
                          || get(/databases/$(database)/documents/families/$(familyId)).data.createdBy == request.auth.uid);
        // Member can leave, or admin can remove
        allow delete: if isAuthenticated()
                      && (request.auth.uid == memberUid
                          || get(/databases/$(database)/documents/families/$(familyId)).data.createdBy == request.auth.uid);
      }
    }

    // ============================================================
    // V3: USER INBOX — Per-User Conversation Thread Metadata
    // Path: user_inbox/{uid}/threads/{conversationId}
    // ============================================================

    match /user_inbox/{userId} {
      allow read: if isOwner(userId);

      match /threads/{threadId} {
        allow read: if isOwner(userId);
        // SECURITY FIX: Only allow writes from conversation participants (not any authenticated user).
        // The threadId IS the conversationId — check if the writer is in that conversation's participants.
        // Fallback: allow the inbox owner to write to their own inbox (self-write for cleanup/mark-read).
        allow create, update: if isOwner(userId)
                              || (
                                isAuthenticated()
                                && exists(/databases/$(database)/documents/conversations/$(threadId))
                                && get(/databases/$(database)/documents/conversations/$(threadId)).data.participants is list
                                && userId in get(/databases/$(database)/documents/conversations/$(threadId)).data.participants
                                && request.auth.uid in get(/databases/$(database)/documents/conversations/$(threadId)).data.participants
                                && (!('conversationId' in request.resource.data) || request.resource.data.conversationId == threadId)
                              );
        allow delete: if isOwner(userId);
      }
    }

    // ============================================================
    // V3: SOS ALERTS — UID-Centric SOS
    // Path: sos_alerts/{uid}/items/{signalId}
    // ============================================================

    match /sos_alerts/{userId} {
      // SECURITY FIX: Only owner or family members can read SOS alerts
      // Previously any authenticated user could read any user's SOS alert history
      allow read: if isAuthenticated()
                  && (isOwner(userId) || sharesFamilyWith(userId));

      // SECURITY FIX: senderUid is MANDATORY and must match auth.uid to prevent SOS spoofing
      // ANTI-ABUSE: Timestamp must be recent (within 5 min) to prevent replay attacks
      match /items/{signalId} {
        allow read: if isAuthenticated()
                    && (isOwner(userId) || sharesFamilyWith(userId));
        allow create: if isAuthenticated()
                      && request.resource.data.timestamp is number
                      && isRecentClientTimestamp(request.resource.data.timestamp)
                      && request.resource.data.senderUid is string
                      && request.resource.data.senderUid == request.auth.uid
                      && (isOwner(userId) || sharesFamilyWith(userId));
        // CRITICAL FIX: Allow SOS sender to update (cancel) their own alerts on family member paths.
        // Previously only the path owner (family member) could update → SOS cancellation SILENTLY FAILED.
        // The SOS sender's UID is stored in resource.data.senderUid at creation time.
        allow update: if isOwner(userId)
                      || (isAuthenticated() && resource.data.senderUid == request.auth.uid);
        allow delete: if false; // SOS records are preserved
      }

      // V3: Rescue ACKs — any authenticated user can ACK (rescuers may not be family)
      match /acks/{ackId} {
        allow read: if isAuthenticated()
                    && (isOwner(userId)
                        || resource.data.userId == request.auth.uid
                        || resource.data.rescuerUid == request.auth.uid);
        allow create: if isAuthenticated()
                      && request.resource.data.timestamp is number
                      && request.resource.data.userId is string
                      && request.resource.data.userId == request.auth.uid
                      && (!('rescuerUid' in request.resource.data)
                          || request.resource.data.rescuerUid == request.auth.uid);
        allow update: if false; // ACKs are immutable
        allow delete: if false;
      }
    }

    // ============================================================
    // V3: CONVERSATIONS — UID-Centric Conversation Threads
    // Each conversation has a messages subcollection for real-time sync
    // ============================================================

    match /conversations/{conversationId} {
      // Participants can read conversation metadata
      allow read: if isAuthenticated()
                  && (resource.data.participants is list)
                  && (request.auth.uid in resource.data.participants);
      // Any authenticated user can create a conversation (must be participant)
      allow create: if isAuthenticated()
                    && request.resource.data.participants is list
                    && request.auth.uid in request.resource.data.participants;
      // Only participants can update (typing, last message, etc.)
      allow update: if isAuthenticated()
                    && resource.data.participants is list
                    && request.auth.uid in resource.data.participants
                    && (
                      isConversationMetadataUpdate()
                      || isConversationTypingUpdate()
                      || isConversationGroupProfileUpdate()
                      || isConversationMembershipUpdate()
                    );
      allow delete: if false;

      // Messages subcollection — V3: senderUid validation
      match /messages/{messageId} {
        allow read: if isAuthenticated()
                    && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants is list
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        // V3: Validate senderUid matches auth.uid AND sender is a participant (prevent spoofing + unauthorized writes)
        // SECURITY FIX: Validate media fields when present (prevent injection of invalid mediaType values)
        // ANTI-ABUSE: Timestamp must be recent (within 5 min), content size limited to 5000 chars
        allow create: if isAuthenticated()
                      && request.resource.data.senderUid == request.auth.uid
                      && request.resource.data.content is string
                      && request.resource.data.content.size() <= 5000
                      && request.resource.data.timestamp is number
                      && isRecentClientTimestamp(request.resource.data.timestamp)
                      && (!('mediaType' in request.resource.data)
                          || request.resource.data.mediaType in ['image', 'voice', 'location'])
                      && (!('mediaDuration' in request.resource.data)
                          || request.resource.data.mediaDuration is number)
                      && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants is list
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                      && passesConversationMessageRateLimit(conversationId)
                      && notBlockedByServerMessageRateLimit();
        // Participants may only write receipt state; only the original sender may
        // edit/delete message content. This prevents conversation members from
        // rewriting another user's emergency/chat content.
        allow update: if isConversationParticipant(conversationId)
                      && (
                        isConversationMessageReceiptUpdate()
                        || isConversationMessageSenderUpdate()
                      );
        allow delete: if false; // Messages are preserved
      }
    }

    // ============================================================
    // NEW: CIRCLES — Family/Friend Circles (Life360 pattern)
    // Owner manages circle, members can read and post updates
    // ============================================================

    match /circles/{circleId} {
      allow read: if isAuthenticated()
                  && (resource.data.ownerUid == request.auth.uid
                      || request.auth.uid in resource.data.memberUids);
      allow create: if isAuthenticated()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.name is string;
      allow update: if isAuthenticated()
                    && resource.data.ownerUid == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.ownerUid == request.auth.uid;
    }

    // ============================================================
    // NEW: GEOFENCES — Per-User Place Alerts (Life360 pattern)
    // User can create geofences around places (home, school, work)
    // ============================================================

    match /geofences/{userId} {
      allow read: if isOwner(userId);

      match /fences/{fenceId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.name is string
                      && request.resource.data.latitude is number
                      && request.resource.data.longitude is number
                      && request.resource.data.radius is number
                      && request.resource.data.radius > 0
                      && request.resource.data.radius <= 10000;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ============================================================
    // GLOBAL SOS BROADCASTS (Proximity-based, ALL users)
    // Life-saving: Any authenticated user can broadcast SOS
    // Any authenticated user can read to receive nearby SOS alerts
    // ============================================================

    match /sos_broadcasts/{broadcastId} {
      // Global broadcast docs are private. Cloud Functions perform geo-distance checks
      // and fan out eligible alerts into sos_alerts/{uid}/items for recipients.
      allow read: if isAuthenticated() && resource.data.senderUid == request.auth.uid;
      // SECURITY FIX: Bind creatorUid to auth.uid to prevent spoofed SOS broadcasts
      // ANTI-ABUSE: Timestamp must be recent (within 5 min) to prevent replay attacks
      //
      // P0-10 (Phase 0): sos_broadcasts is the GLOBAL proximity channel — Cloud
      // Functions fan it out to nearby users via geo-distance. Without a
      // location, "nearby" is meaningless, so a global broadcast with no lat/lng
      // would spam every nearby user incorrectly OR be silently dropped by the
      // geo-query CF (worse: user thinks SOS is broadcasting but no one nearby
      // receives it). Now latitude AND longitude are REQUIRED and must be
      // finite numbers in valid range. Mesh/Firebase per-family channels still
      // work without location — they use the device path, not the global path.
      //
      // NOTE (FIX 12): Rate limiting (e.g., max 1 active SOS per user per 5 min) cannot be
      // reliably enforced in Firestore rules alone — rules lack query capabilities to check
      // for existing active broadcasts from the same senderUid. This MUST be enforced
      // server-side in the onSOSBroadcast Cloud Function or via a dedicated rate_limits
      // collection. For now, the timestamp check provides basic replay protection and
      // notBlockedByServerSosRateLimit() provides server-driven blocking.
      allow create: if isAuthenticated()
                    && request.resource.data.signalId is string
                    && !('healthInfo' in request.resource.data)
                    && request.resource.data.latitude is number
                    && request.resource.data.latitude >= -90
                    && request.resource.data.latitude <= 90
                    && request.resource.data.longitude is number
                    && request.resource.data.longitude >= -180
                    && request.resource.data.longitude <= 180
                    && request.resource.data.timestamp is number
                    && isRecentClientTimestamp(request.resource.data.timestamp)
                    && request.resource.data.senderUid is string
                    && request.resource.data.senderUid == request.auth.uid
                    && notBlockedByServerSosRateLimit()
                    // SECURITY: Validate senderName length to prevent abuse via oversized payloads
                    && (!('senderName' in request.resource.data) || (request.resource.data.senderName is string && request.resource.data.senderName.size() <= 100));
      // CRITICAL FIX: Allow the SOS creator to update their own broadcast (cancellation).
      // Without this, cancelSOS() → updateDoc(sos_broadcasts/{id}, {status:'cancelled'})
      // is SILENTLY REJECTED, and NearbySOSListener never sees the cancellation.
      // All nearby users continue seeing an active SOS forever.
      allow update: if isAuthenticated()
                    && resource.data.senderUid == request.auth.uid
                    && request.resource.data.senderUid == resource.data.senderUid
                    && request.resource.data.signalId == resource.data.signalId
                    && request.resource.data.latitude == resource.data.latitude
                    && request.resource.data.longitude == resource.data.longitude
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'status',
                      'cancelledAt',
                      'updatedAt'
                    ])
                    && request.resource.data.status in ['cancelled', 'resolved'];
      allow delete: if false; // Cleanup via TTL or Cloud Functions

      // SOS Acknowledgements — delivery confirmation from recipients
      match /acks/{ackId} {
        allow read: if isAuthenticated()
                    && (
                      get(/databases/$(database)/documents/sos_broadcasts/$(broadcastId)).data.senderUid == request.auth.uid
                      || resource.data.userId == request.auth.uid
                      || resource.data.rescuerUid == request.auth.uid
                    );
        allow create: if isAuthenticated()
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.timestamp is number;
        allow update: if false;
        allow delete: if false;
      }
    }

    // ============================================================
    // CLOUD FUNCTIONS-ONLY COLLECTIONS (Admin SDK bypass rules)
    // Explicit deny for client access — documentation only
    // ============================================================

    // Email logs (Cloud Functions sendCustomEmail writes here)
    match /email_logs/{logId} {
      allow read, write: if false; // Only via Cloud Functions with admin SDK
    }

    // Rate limits for server-side (Cloud Functions) rate limiting
    // Owner can read their own rate limit status; only Cloud Functions can write
    match /rate_limits/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can write
    }

    // ============================================================
    // REPORTS COLLECTION - UGC Moderation (Apple Guideline 1.2)
    // Users can create reports and read their own reports.
    // Only admins/Cloud Functions can update or delete reports.
    // ============================================================
    match /reports/{reportId} {
      // Users can read their own reports (check status)
      allow read: if isAuthenticated()
                  && resource.data.reporterId == request.auth.uid;

      // Users can create reports — must be their own UID as reporterId
      allow create: if isAuthenticated()
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.reportType is string
                    && request.resource.data.reason is string
                    && request.resource.data.reasonLabel is string
                    && request.resource.data.status == 'pending'
                    && request.resource.data.createdAt is number
                    && isRecentClientTimestamp(request.resource.data.createdAt);

      // Users cannot update or delete reports — only admins/Cloud Functions
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // FEEDBACK COLLECTION - In-app user feedback (bug/feature/praise)
    // Sprint 2: In-app feedback widget
    // ============================================================
    match /feedback/{feedbackId} {
      // Users can read their own feedback
      allow read: if isAuthenticated()
                  && resource.data.uid == request.auth.uid;

      // Users can submit feedback — must be their own UID
      // Rate limiting handled client-side (modal is gated by user action)
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.type in ['bug', 'feature', 'praise', 'other']
                    && request.resource.data.message is string
                    && request.resource.data.message.size() >= 3
                    && request.resource.data.message.size() <= 5000;

      // Only admins can update/delete (e.g., responses, GDPR deletion)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Catch-all deny for undefined paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
