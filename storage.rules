rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Elite Security Functions
    function isSystemClient() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Elite Security: User profile images - STRICT access control
    // SECURITY FIX: userId is Firebase Auth UID (28-char alphanumeric), NOT AFN device ID.
    // Using request.auth.uid == userId ensures only the owner can write their own profile image.
    // Any authenticated user can read profiles (needed to display other users' avatars).
    match /profiles/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.metadata.ownerUid == request.auth.uid &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      request.resource.contentType.matches('image/.*');
      allow delete: if isSystemClient() ||
                       (isAuthenticated() && request.auth.uid == userId);
    }
    
    // Elite Security: Emergency SOS images - Public read for emergency, strict write
    // SECURITY FIX: Write requires authentication (removed metadata-only fallback)
    match /sos/{sosId}/{allPaths=**} {
      allow read: if true; // Public read for emergency response (life-saving)
      allow write: if isAuthenticated() &&
                      request.resource.size <= 10 * 1024 * 1024 && // Max 10MB
                      request.resource.contentType.matches('(image|video|audio)/.*');
      allow delete: if isSystemClient() || 
                       (isAuthenticated() && resource.metadata.ownerUid == request.auth.uid);
    }
    
    // Elite Security: Family member images - STRICT access control
    // SECURITY FIX: deviceId in this path corresponds to a Firebase Auth UID (primary key),
    // not an AFN-format device ID. Using request.auth.uid == deviceId ensures only the
    // family group owner can write images. Any authenticated user can read (for family sharing).
    match /family/{deviceId}/{memberId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == deviceId &&
                      request.resource.metadata.ownerUid == request.auth.uid &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      request.resource.contentType.matches('image/.*');
      allow delete: if isSystemClient() ||
                       (isAuthenticated() && request.auth.uid == deviceId &&
                        resource.metadata.ownerUid == request.auth.uid);
    }
    
    // Voice messages - Owner-write, authenticated-read
    // SECURITY MODEL: Recipients receive download URLs via Firestore messages,
    // which are participant-restricted (conversations/{id}/messages with senderUid
    // validation). Storage rules cannot query Firestore to verify conversation
    // membership, so read access is auth-gated. Firebase Storage download URLs
    // contain a signed token and are not enumerable or guessable.
    // Write is path-restricted: only the UID path owner can upload.
    match /voice/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.size <= 2 * 1024 * 1024 && // Max 2MB (30s audio)
                      request.resource.contentType.matches('audio/.*');
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Chat media (images, voice in conversations)
    // SECURITY MODEL: Files are uploaded to chat/{sender.uid}/timestamp.ext.
    // Recipients receive download URLs via Firestore messages, which are
    // participant-restricted (conversations/{id}/messages with senderUid validation).
    // Storage rules cannot query Firestore for conversation membership, so read
    // access requires authentication only. Firebase Storage download URLs contain
    // a signed token and are not enumerable or guessable.
    // Write is path-restricted: only the UID path owner can upload.
    match /chat/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      (request.resource.contentType.matches('image/.*') ||
                       request.resource.contentType.matches('audio/.*'));
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Group chat media (family/group conversation attachments)
    // Path: group-chat/{groupId}/{ownerUid}/{file}
    // SECURITY MODEL: Same as chat media — Firestore family/conversation rules
    // control who receives the download URL. Storage read is auth-gated since
    // Storage rules cannot verify group membership. Download URLs contain a
    // signed token and are not enumerable or guessable.
    // Write is path-restricted: only the UID path owner can upload.
    match /group-chat/{groupId}/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.size <= 10 * 1024 * 1024 &&
                      (request.resource.contentType.matches('image/.*') ||
                       request.resource.contentType.matches('audio/.*'));
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // MBTiles offline maps (read-only, uploaded via admin)
    match /maps/{mapId}/{allPaths=**} {
      allow read: if true; // Public read for offline maps
      allow write: if false; // Only admins can upload (via admin SDK)
      allow delete: if false;
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
