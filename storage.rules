rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Elite Security Functions
    function isSystemClient() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidDeviceId(deviceId) {
      return deviceId != null && 
             deviceId is string && 
             deviceId.matches('^[Aa][Ff][Nn]-[A-Za-z0-9]{8}$') &&
             deviceId.size() == 12;
    }

    // Elite Security: User profile images - STRICT access control
    // SECURITY FIX: ownerUid metadata must match auth.uid to prevent IDOR
    match /profiles/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && isValidDeviceId(userId);
      allow write: if isAuthenticated() && 
                      isValidDeviceId(userId) &&
                      request.resource.metadata.ownerUid == request.auth.uid &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      request.resource.contentType.matches('image/.*');
      allow delete: if isSystemClient() || 
                       (isAuthenticated() && isValidDeviceId(userId) &&
                        resource.metadata.ownerUid == request.auth.uid);
    }
    
    // Elite Security: Emergency SOS images - Public read for emergency, strict write
    // SECURITY FIX: Write requires authentication (removed metadata-only fallback)
    match /sos/{sosId}/{allPaths=**} {
      allow read: if true; // Public read for emergency response (life-saving)
      allow write: if isAuthenticated() &&
                      request.resource.size <= 10 * 1024 * 1024 && // Max 10MB
                      request.resource.contentType.matches('(image|video|audio)/.*');
      allow delete: if isSystemClient() || 
                       (isAuthenticated() && resource.metadata.ownerUid == request.auth.uid);
    }
    
    // Elite Security: Family member images - STRICT access control
    // SECURITY FIX: ownerUid metadata must match auth.uid to prevent IDOR
    match /family/{deviceId}/{memberId}/{allPaths=**} {
      allow read: if isAuthenticated() && isValidDeviceId(deviceId);
      allow write: if isAuthenticated() && 
                      isValidDeviceId(deviceId) &&
                      request.resource.metadata.ownerUid == request.auth.uid &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      request.resource.contentType.matches('image/.*');
      allow delete: if isSystemClient() || 
                       (isAuthenticated() && isValidDeviceId(deviceId) &&
                        resource.metadata.ownerUid == request.auth.uid);
    }
    
    // Elite Security: Voice messages - Owner access only
    match /voice/{userId}/{allPaths=**} {
      // CRITICAL FIX: Any authenticated user can read voice messages
      // Recipients need access to voice messages sent TO them.
      // The sender uploads to voice/{sender.uid}/... but the recipient
      // receives the download URL via Firestore message — which is
      // already access-controlled. Without this fix, recipients get
      // PERMISSION_DENIED when trying to play received voice messages.
      allow read: if isAuthenticated();
      // Elite: Only owner can write with size/type validation
      allow write: if isAuthenticated() && 
                      request.auth.uid == userId &&
                      request.resource.size <= 2 * 1024 * 1024 && // Max 2MB (30s audio)
                      request.resource.contentType.matches('audio/.*');
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Elite Security: Chat media (images, voice in conversations)
    match /chat/{userId}/{allPaths=**} {
      // CRITICAL FIX: Any authenticated user can read chat media.
      // When User A sends an image to User B, the file is uploaded to
      // chat/{A.uid}/timestamp.jpg. User B receives the download URL
      // via Firestore (devices/{B}/messages/{msgId}.mediaUrl). Without
      // this fix, User B gets PERMISSION_DENIED loading the image.
      // Security: URLs are unguessable (timestamp-based) and Firestore
      // controls who sees the mediaUrl (inbox owner + linked family).
      allow read: if isAuthenticated();
      // Elite: Only owner can write with size/type validation
      allow write: if isAuthenticated() && 
                      request.auth.uid == userId &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      (request.resource.contentType.matches('image/.*') ||
                       request.resource.contentType.matches('audio/.*'));
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Elite Security: Group chat media (family/group conversation attachments)
    // Path used by FamilyGroupChatScreen: group-chat/{groupId}/{ownerUid}/{file}
    // Reads are auth-gated; writes are owner-only by UID path segment.
    match /group-chat/{groupId}/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.size <= 10 * 1024 * 1024 &&
                      (request.resource.contentType.matches('image/.*') ||
                       request.resource.contentType.matches('audio/.*'));
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // MBTiles offline maps (read-only, uploaded via admin)
    match /maps/{mapId}/{allPaths=**} {
      allow read: if true; // Public read for offline maps
      allow write: if false; // Only admins can upload (via admin SDK)
      allow delete: if false;
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
