rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Elite Security Functions
    function isSystemClient() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Elite Security: User profile images - STRICT access control
    // SECURITY FIX: userId is Firebase Auth UID (28-char alphanumeric), NOT AFN device ID.
    // Using request.auth.uid == userId ensures only the owner can write their own profile image.
    // Any authenticated user can read profiles (needed to display other users' avatars).
    match /profiles/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.metadata.ownerUid == request.auth.uid &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      request.resource.contentType.matches('image/.*');
      allow delete: if isSystemClient() ||
                       (isAuthenticated() && request.auth.uid == userId);
    }
    
    // Elite Security: Emergency SOS media.
    // In-app responders are authenticated; public unauthenticated reads would expose
    // emergency photos/audio if a download path leaks. The first path segment is the
    // uploader Firebase Auth UID, matching account-deletion cleanup paths.
    match /sos/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.metadata.ownerUid == request.auth.uid &&
                      request.resource.size <= 10 * 1024 * 1024 && // Max 10MB
                      request.resource.contentType.matches('(image|video|audio)/.*');
      allow delete: if isSystemClient() || 
                       (isAuthenticated() && request.auth.uid == userId &&
                        resource.metadata.ownerUid == request.auth.uid);
    }
    
    // Elite Security: Family member images - STRICT access control
    // SECURITY FIX: deviceId in this path corresponds to a Firebase Auth UID (primary key),
    // not an AFN-format device ID. Using request.auth.uid == deviceId ensures only the
    // family group owner can write images. Any authenticated user can read (for family sharing).
    match /family/{deviceId}/{memberId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      request.auth.uid == deviceId &&
                      request.resource.metadata.ownerUid == request.auth.uid &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      request.resource.contentType.matches('image/.*');
      allow delete: if isSystemClient() ||
                       (isAuthenticated() && request.auth.uid == deviceId &&
                        resource.metadata.ownerUid == request.auth.uid);
    }
    
    // Voice messages - Owner-write, recipient-or-owner read.
    // P0-10: Uploaders MUST set metadata.uploaderUid and metadata.recipientUids.
    match /voice/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        (resource.metadata != null && resource.metadata.uploaderUid == request.auth.uid) ||
        (resource.metadata != null && resource.metadata.recipientUids != null &&
         resource.metadata.recipientUids.matches('(^|,)' + request.auth.uid + '(,|$)'))
      );
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.metadata.uploaderUid == request.auth.uid &&
                      request.resource.size <= 2 * 1024 * 1024 && // Max 2MB (30s audio)
                      request.resource.contentType.matches('audio/.*');
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Chat media (images, voice in conversations).
    //
    // P0-10 (Phase 0): Read access is now uploader-or-recipient gated using
    // file metadata. Uploaders MUST write the following custom metadata keys:
    //   • uploaderUid   — must equal request.auth.uid
    //   • recipientUids — comma-separated UIDs allowed to read the file
    // A recipient that is not listed cannot read the object even with a valid
    // download URL — the previous "any authenticated user" rule was too
    // permissive given that Firebase Storage download URLs can be forwarded.
    match /chat/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        (resource.metadata != null && resource.metadata.uploaderUid == request.auth.uid) ||
        (resource.metadata != null && resource.metadata.recipientUids != null &&
         resource.metadata.recipientUids.matches('(^|,)' + request.auth.uid + '(,|$)'))
      );
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.metadata.uploaderUid == request.auth.uid &&
                      request.resource.size <= 5 * 1024 * 1024 && // Max 5MB
                      (request.resource.contentType.matches('image/.*') ||
                       request.resource.contentType.matches('audio/.*'));
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Group chat media (family/group conversation attachments)
    // Path: group-chat/{groupId}/{ownerUid}/{file}
    //
    // P0-10: Same uploader-or-recipient gating as chat/, plus the upload must
    // tag the groupId in metadata so a future per-group rule can be applied
    // without re-uploading.
    match /group-chat/{groupId}/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        (resource.metadata != null && resource.metadata.uploaderUid == request.auth.uid) ||
        (resource.metadata != null && resource.metadata.recipientUids != null &&
         resource.metadata.recipientUids.matches('(^|,)' + request.auth.uid + '(,|$)'))
      );
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      request.resource.metadata.uploaderUid == request.auth.uid &&
                      request.resource.size <= 10 * 1024 * 1024 &&
                      (request.resource.contentType.matches('image/.*') ||
                       request.resource.contentType.matches('audio/.*'));
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // MBTiles offline maps (read-only, uploaded via admin)
    match /maps/{mapId}/{allPaths=**} {
      allow read: if true; // Public read for offline maps
      allow write: if false; // Only admins can upload (via admin SDK)
      allow delete: if false;
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
